# =============================================================================
# Coder Stack — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to the repository.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=coder
POSTGRES_USER=coder
POSTGRES_PASSWORD=changeme              # REQUIRED — use a strong random password

# --- Coder ---
# Public URL used by users and workspace agents to reach the Coder server.
# tsdproxy registers this container as https://coder.tailaa3fee.ts.net in the
# Tailnet and handles TLS termination. Change only if you rename the tsdproxy
# machine name (tsdproxy.name label in docker-compose.yml).
CODER_ACCESS_URL=https://coder.tailaa3fee.ts.net

# CODER_WILDCARD_ACCESS_URL is intentionally NOT set.
# tsdproxy does not support wildcard subdomains. VS Code Web is served via
# Coder's path-based proxy (no wildcard DNS required).

# Coder image version — pin to a specific release in production.
# See https://github.com/coder/coder/releases
CODER_VERSION=2.20.0

# Port Coder listens on inside the container and on the host.
# tsdproxy proxies HTTPS → this port. Keep default unless you have a conflict.
CODER_HTTP_PORT=7080

# Log level: debug | info | warn | error
CODER_LOG_LEVEL=info

# Disable anonymous telemetry
CODER_TELEMETRY_ENABLE=false
