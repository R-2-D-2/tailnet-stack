# =============================================================================
# Coder Stack — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to the repository.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=coder
POSTGRES_USER=coder
POSTGRES_PASSWORD=changeme              # REQUIRED — use a strong random password

# --- Coder ---
# Full URL used by users and workspace agents to reach the Coder server.
# Use your Tailscale MagicDNS hostname, e.g. http://myhost.tailXXXX.ts.net:7080
CODER_ACCESS_URL=http://your-tailnet-host:7080

# Wildcard URL for workspace port-forwarding (optional but recommended).
# Must be a wildcard subdomain of CODER_ACCESS_URL host, e.g.:
#   *.myhost.tailXXXX.ts.net  →  CODER_WILDCARD_ACCESS_URL=*.myhost.tailXXXX.ts.net:7080
CODER_WILDCARD_ACCESS_URL=

# Coder image version (pin to a specific release in production)
# See https://github.com/coder/coder/releases
CODER_VERSION=2.20.0

# Port Coder listens on (host side)
CODER_HTTP_PORT=7080

# Log level: debug | info | warn | error
CODER_LOG_LEVEL=info

# Disable anonymous telemetry
CODER_TELEMETRY_ENABLE=false
